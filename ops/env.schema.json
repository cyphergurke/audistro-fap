{
  "service": "audistro-fap",
  "keys": [
    { "key": "AUDISTRO_ENV", "required_in_prod": true, "pattern": "^(prod|dev|test)$", "redact": false },
    { "key": "FAP_MASTER_KEY_HEX", "required_in_prod": true, "pattern": "^[A-Fa-f0-9]{64}$", "redact": true },
    { "key": "FAP_WEBHOOK_SECRET", "required_in_prod": true, "pattern": "(?s)^.{1,}$", "redact": true },
    { "key": "FAP_ADMIN_TOKEN", "required_in_prod": true, "pattern": "(?s)^.{1,}$", "redact": true }
  ]
}
